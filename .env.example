PORT=5001
JWT_SECRET=replace_with_a_long_random_secret_before_deploy
CORS_ORIGIN=true

# Email password-reset delivery (https://resend.com)
RESEND_API_KEY=re_your_api_key
RESET_FROM_EMAIL=CareerForge AI <reset@your-verified-domain.com>

# SMS password-reset delivery (https://twilio.com)
TWILIO_ACCOUNT_SID=AC_your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Optional alternatives: POST webhooks receive to, code, subject, and message
# RESET_EMAIL_WEBHOOK=https://your-service.example/send-email
# RESET_SMS_WEBHOOK=https://your-service.example/send-sms
